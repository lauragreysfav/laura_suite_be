# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# TorBox
TORBOX_API_KEY=your-torbox-api-key
TORBOX_WEBDAV_USER=your-webdav-email
TORBOX_WEBDAV_PASS=your-webdav-password
TORBOX_WEBDAV_URL=https://webdav.torbox.app

# Stash
STASH_URL=http://stash:9999
STASH_API_KEY=

# Whisparr
WHISPARR_URL=http://whisparr:6969
WHISPARR_API_KEY=your-whisparr-api-key

# Prowlarr
PROWLARR_URL=http://gluetun:9696
PROWLARR_API_KEY=your-prowlarr-api-key

# Database (Postgres)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=laura
DB_USER=laura
DB_PASSWORD=your-db-password

# Typesense
TYPESENSE_HOST=http://typesense:8108
TYPESENSE_API_KEY=your-typesense-api-key

# StashDB Ingest
STASHDB_API_KEY=your-stashdb-api-key

# VPN (Gluetun)
PROTON_VPN_USER=your-vpn-user
PROTON_VPN_PASSWORD=your-vpn-password
GLUETUN_TOKEN=your-gluetun-token

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email

# Backend General
DATABASE_PATH=/data/laura.db
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-string
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
